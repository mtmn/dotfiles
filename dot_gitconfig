[user]
    name = mtmn
    email = miro@haravara.org

[includeIf "gitdir:~/git/work/"]
    path = ~/git/work/.gitconfig

[color]
    ui = auto
[push]
    default = current
[merge]
    tool = vimdiff
    conflictstyle = diff3
[rebase]
    autosquash = true
[alias]
    why-ignore = check-ignore -v
    gitlab-mr = push -o merge_request.create -o merge_request.target=master

[url "https://github/"]
    insteadOf = "gh:"
[url "git@github.com:"]
    pushInsteadOf = "gh:"
[pull]
    rebase = false
