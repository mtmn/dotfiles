[user]
    name = mtmn
    email = miro@haravara.org

[includeIf "gitdir:/git/work/"]
    path = ~/git/work/.gitconfig

[color]
    ui = auto
[push]
    default = current
[merge]
    tool = vimdiff
    conflictstyle = diff3
[rebase]
    autosquash = true
[alias]
    why-ignore = check-ignore -v

[url "https://github/"]
    insteadOf = "gh:"
[url "git@github.com:"]
    pushInsteadOf = "gh:"
