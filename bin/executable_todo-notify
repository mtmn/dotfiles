#!/bin/bash

TODO_FILE="$HOME/misc/notes/nota/todo.txt"
current_date=""

while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2} ]]; then
        current_date="$line"
    elif [[ "$line" =~ ^todo:\ (.*)$ ]]; then
        todo_message="${BASH_REMATCH[1]}"
        notify-send "$current_date" "$todo_message"
        wait
    fi
done < "$TODO_FILE"
