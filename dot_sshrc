export PATH="$PATH:$HOME/go/bin"
export GOPATH="$HOME/go"

alias q='sudo '
alias dfh='df -h /'
alias duh='du -hs .'

alias lopri='nice -n 19 ionice -c2 -n7 '
alias scan='sudo nmap -n -PN -sT -sU -p-'

alias ss='sudo systemctl start'
alias st='sudo systemctl stop'
alias sd='sudo systemctl -n 100 status'

alias us='systemctl --user start'
alias ut='systemctl --user stop'
alias ud='systemctl --user -n 100 status'

mkdir -p ~/.config/shell/rc

cp "$SSHHOME/.sshrc.d/vimrc" ~/.vimrc
cp "$SSHHOME/.sshrc.d/tmuxconf" ~/.config/.tmux.conf

cp "$SSHHOME/.sshrc.d/early-funcs" ~/.config/shell

cp "$SSHHOME/.sshrc.d/git" ~/.config/shell/rc
cp "$SSHHOME/.sshrc.d/jujutsu" ~/.config/shell/rc
cp "$SSHHOME/.sshrc.d/prompt-functions" ~/.config/shell/rc
cp "$SSHHOME/.sshrc.d/aliased-short-names" ~/.config/shell/rc

cp "$SSHHOME/.sshrc.d/bashrc" ~/.bashrc

source ~/.bashrc
